Options -Indexes
DirectoryIndex client.html
RewriteEngine On

# 1. Let real files be served as-is (client.html, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# 2. Route /api/* to the PHP backend
RewriteRule ^api(/.*)?$ index.php [L,QSA]

# 3. Everything else → frontend
RewriteRule ^ client.html [L]
